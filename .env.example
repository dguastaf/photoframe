PHOTO_SOURCE=photoprism # There may be other sources in the future.

PHOTOPRISM_BASE_URL=http://photoprism.local:2342
PHOTOPRISM_TOKEN=replace-me

# Ports: defaults in config/ports.env (PHOTOFRAME_SERVER_PORT, PHOTOFRAME_CLIENT_PORT, …).
# CORS_ORIGINS: optional; when unset, defaults to the client dev origin from those ports.
# Set CORS_ORIGINS= (empty) when UI and API share one host (reverse proxy).
