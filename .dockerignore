# Repo-root build context (docker-compose: context: .)
# server/.dockerignore is not applied when context is the repository root.

*
!server/
!client/
!config/

# Server dev artifacts (aligned with server/.dockerignore)
server/__pycache__/
server/**/*.py[cod]
server/**/*$py.class
server/**/*.egg-info/
server/.pytest_cache/
server/.ruff_cache/
server/.mypy_cache/
server/.venv/
server/venv/
server/tests/
server/.env

# Client dev artifacts
client/node_modules/
client/tests/
client/.gitignore
client/TESTING.md
client/eslint.config.js

# Repo tooling (redundant with * but explicit for readers)
.git/
.github/
.cursor/
.vscode/
.env
.env.*
docker-compose.yml
README.md
